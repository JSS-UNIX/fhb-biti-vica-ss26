  "resources": [
    {
      "mode": "data",
      "type": "exoscale_template",
      "name": "ubuntu",
      "provider": "provider[\"registry.terraform.io/exoscale/exoscale\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "default_user": "ubuntu",
            "id": "f8d6fbf7-ffa7-45e2-bed8-d101d814d646",
            "name": "Linux Ubuntu 24.04 LTS 64-bit",
